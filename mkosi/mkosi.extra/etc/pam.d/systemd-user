# Used by systemd --user instances.
# Normally provided by /usr/lib/pam.d/systemd-user (from the systemd package)
# but some PAM configurations don't fall back to /usr/lib/pam.d/.  Installing
# it explicitly in /etc/pam.d/ ensures systemd --user sessions work.

auth       include    system-auth

account    include    system-login

session    required   pam_loginuid.so
session    optional   pam_keyinit.so       force revoke
session    include    system-auth
session    optional   pam_umask.so
session    optional   pam_systemd.so
session    required   pam_env.so
